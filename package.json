{
  "name": "@synergenius/flowweaver-pack-cicd",
  "version": "0.2.0",
  "description": "CI/CD pipeline infrastructure and node types for Flow Weaver: tag handler, validation rules, job graph builder, and platform-native CI/CD node stubs",
  "keywords": [
    "flowweaver-marketplace-pack",
    "flow-weaver",
    "cicd",
    "github-actions",
    "gitlab-ci",
    "pipeline",
    "devops"
  ],
  "flowWeaver": {
    "type": "marketplace-pack",
    "engineVersion": ">=0.17.7",
    "categories": ["cicd", "automation", "devops"]
  },
  "peerDependencies": {
    "@synergenius/flow-weaver": ">=0.17.7"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "type": "module",
  "files": [
    "dist",
    "flowweaver.manifest.json",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "pack:manifest": "flow-weaver market pack",
    "prepublishOnly": "npm run build && npm run pack:manifest"
  },
  "devDependencies": {
    "typescript": "^5.0.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/synergenius-fw/flowweaver-pack-cicd"
  }
}
